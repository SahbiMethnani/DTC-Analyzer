# ─────────────────────────────────────────────────────────────
# .env — Variables d'environnement DTC Dashboard WPM XCT
# Copiez ce fichier en .env et adaptez les valeurs
# ─────────────────────────────────────────────────────────────

# ── Base de données MySQL ─────────────────────────────────────
DB_HOST=localhost
DB_NAME=dtc_db
DB_USER=root
DB_PASSWORD=votre_mot_de_passe
DB_PORT=3306
DB_POOL_NAME=dtc_pool
DB_POOL_SIZE=5

# ── Application ───────────────────────────────────────────────
APP_TITLE=DTC Dashboard · WPM XCT
APP_DEBUG=false

# ── Chemins des exécutables (jobs) ───────────────────────────
JOB1_PATH=jobs/job1.exe
JOB1_LABEL=Job 1 — Acquisition
JOB2_PATH=jobs/job2.exe
JOB2_LABEL=Job 2 — Traitement

# ── Sécurité — Page Contrôle ─────────────────────────────────
CONTROL_PASSWORD=admin123
