# ─────────────────────────────────────────────────────────────
# .gitignore — DTC Dashboard WPM XCT
# ─────────────────────────────────────────────────────────────

# ── Environnement & secrets ───────────────────────────────────
.env
*.env
!.env.example

# ── Environnements virtuels Python ───────────────────────────
venv/
.venv/
env/
ENV/
.Python

# ── Cache Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# ── Streamlit ─────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Jobs & exécutables ────────────────────────────────────────
jobs/*.exe
jobs/*.bat
jobs/*.dll
jobs/*.log

# ── Exports générés ───────────────────────────────────────────
*.xlsx
*.pdf
!template_dtc.xlsx

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── OS ────────────────────────────────────────────────────────
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Mac
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~

# ── IDE ───────────────────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ── Distribution / Build ──────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/
MANIFEST

# ── Tests ─────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Données sensibles ─────────────────────────────────────────
*.csv
*.sql
*.db
*.sqlite
*.sqlite3
appc.py
